{
  "manifest_version": 3,
  "name": "Focus Sessions",
  "description": "Locally log why you use sites and how long each tab stays active.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Focus Sessions"
  },
  "options_page": "stats.html"
}
